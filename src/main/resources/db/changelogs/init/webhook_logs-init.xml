<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-webhook_logs-table" author="Nikita">
        <createTable tableName="webhook_logs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="endpoint_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="attempt" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="status_code" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="request_body" type="VARCHAR(MAX)">
                <constraints nullable="true"/>
            </column>
            <column name="response_body" type="VARCHAR(MAX)">
                <constraints nullable="true"/>
            </column>
            <column name="error_message" type="VARCHAR(1000)">
                <constraints nullable="true"/>
            </column>
            <column name="success" type="BIT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="duration_ms" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="sent_at" type="DATETIME" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="webhook_logs"
                baseColumnNames="endpoint_id"
                constraintName="fk_webhook_logs_webhook_endpoints"
                referencedTableName="webhook_endpoints"
                referencedColumnNames="id"/>

        <createIndex tableName="webhook_logs" indexName="idx_webhook_logs_endpoint_id">
            <column name="endpoint_id"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'webhook_logs', 'DATA_TABLE', 'Nikita', 1, 'access_management_service',
                    'Table for logging webhook delivery attempts and responses.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('webhook_logs')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'webhook_logs';</sql>
            <dropTable tableName="webhook_logs"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
