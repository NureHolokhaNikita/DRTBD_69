<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="008-create-events-table" author="Mariia">
        <createTable tableName="events">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="session_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="page_url" type="VARCHAR(2000)">
                <constraints nullable="true"/>
            </column>
            <column name="page_title" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
            <column name="element_selector" type="VARCHAR(MAX)">
                <constraints nullable="true"/>
            </column>
            <column name="element_text" type="VARCHAR(MAX)">
                <constraints nullable="true"/>
            </column>
            <column name="element_role" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="event_data" type="VARCHAR(MAX)">
                <constraints nullable="true"/>
            </column>
            <column name="sequence_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="recorded_at" type="DATETIME" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="events"
                baseColumnNames="session_id"
                constraintName="fk_events_sessions"
                referencedTableName="sessions"
                referencedColumnNames="id"/>

        <createIndex tableName="events" indexName="idx_events_session_id">
            <column name="session_id"/>
        </createIndex>
        <createIndex tableName="events" indexName="idx_events_session_id_sequence">
            <column name="session_id"/>
            <column name="sequence_number"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'events', 'DATA_TABLE', 'Nikita', 1, 'scenario_session_service',
                    'Actions and occurrences within a session (clicks, navigation, payload).',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('events')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'events';</sql>
            <dropTable tableName="events"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
