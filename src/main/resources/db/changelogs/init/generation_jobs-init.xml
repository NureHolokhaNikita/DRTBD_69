<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-create-generation_jobs-table" author="Nikita">
        <createTable tableName="generation_jobs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="scenario_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="total_sessions" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="completed_sessions" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="failed_sessions" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="config_override" type="VARCHAR(MAX)">
                <constraints nullable="true"/>
            </column>
            <column name="schedule_cron" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="DATETIME" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="started_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="finished_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="generation_jobs"
                baseColumnNames="scenario_id"
                constraintName="fk_generation_jobs_scenarios"
                referencedTableName="scenarios"
                referencedColumnNames="id"/>

        <createIndex tableName="generation_jobs" indexName="idx_generation_jobs_scenario_id">
            <column name="scenario_id"/>
        </createIndex>
        <createIndex tableName="generation_jobs" indexName="idx_generation_jobs_status">
            <column name="status"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'generation_jobs', 'DATA_TABLE', 'Nikita', 1, 'scenario_session_service',
                    'Tracks a run or scheduled execution of a scenario (session counts, status, timing).',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('generation_jobs')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'generation_jobs';</sql>
            <dropTable tableName="generation_jobs"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
