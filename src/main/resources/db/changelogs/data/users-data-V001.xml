<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-insert-users-data" author="Nikita">
        <preConditions onFail="HALT">
            <and>
                <tableExists schemaName="dbo" tableName="users"/>
                <columnExists schemaName="dbo" tableName="users" columnName="name"/>
                <columnExists schemaName="dbo" tableName="users" columnName="password"/>
                <columnExists schemaName="dbo" tableName="users" columnName="role"/>
            </and>
        </preConditions>

        <insert tableName="users">
            <column name="name" value="admin"/>
            <column name="password" value="admin_pass_hash"/>
            <column name="role" value="ADMIN"/>
        </insert>
        <insert tableName="users">
            <column name="name" value="alice"/>
            <column name="password" value="alice_pass_hash"/>
            <column name="role" value="USER"/>
        </insert>
        <insert tableName="users">
            <column name="name" value="bob"/>
            <column name="password" value="bob_pass_hash"/>
            <column name="role" value="USER"/>
        </insert>
        <insert tableName="users">
            <column name="name" value="charlie"/>
            <column name="password" value="charlie_pass_hash"/>
            <column name="role" value="USER"/>
        </insert>

        <rollback>
            <delete tableName="users">
                <where>name IN ('admin', 'alice', 'bob', 'charlie')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
