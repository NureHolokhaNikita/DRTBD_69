<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ============================================= -->
    <!--  INIT: Initial table creation                 -->
    <!--  All CREATE TABLE changesets go here           -->
    <!-- ============================================= -->
    <include file="init/tables-init.xml" relativeToChangelogFile="true"/>
    <include file="init/users-init.xml" relativeToChangelogFile="true"/>
    <include file="init/data_api_keys-init.xml" relativeToChangelogFile="true"/>
    <include file="init/webhook_endpoints-init.xml" relativeToChangelogFile="true"/>
    <include file="init/webhook_logs-init.xml" relativeToChangelogFile="true"/>
    <include file="init/scenarios-init.xml" relativeToChangelogFile="true"/>
    <include file="init/generation_jobs-init.xml" relativeToChangelogFile="true"/>
    <include file="init/sessions-init.xml" relativeToChangelogFile="true"/>
    <include file="init/events-init.xml" relativeToChangelogFile="true"/>
    <include file="init/agent_decisions-init.xml" relativeToChangelogFile="true"/>


    <!-- ============================================= -->
    <!--  CHANGES: Schema modifications after init     -->
    <!--  ALTER TABLE, ADD COLUMN, RENAME, etc.        -->
    <!-- ============================================= -->
    <!-- <include file="changes/your-change-file.xml" relativeToChangelogFile="true"/> -->


    <!-- ============================================= -->
    <!--  DATA: Seed data insertions                   -->
    <!--  INSERT statements for reference data         -->
    <!-- ============================================= -->
    <include file="data/users-data-V001.xml" relativeToChangelogFile="true"/>
    <include file="data/data_api_keys-data-V001.xml" relativeToChangelogFile="true"/>
    <include file="data/webhook_endpoints-data-V001.xml" relativeToChangelogFile="true"/>
    <include file="data/webhook_logs-data-V001.xml" relativeToChangelogFile="true"/>


    <!-- ============================================= -->
    <!--  TRIGGERS: Database triggers                  -->
    <!--  AFTER INSERT/UPDATE/DELETE triggers           -->
    <!-- ============================================= -->
    <!-- <include file="triggers/your-trigger-file.xml" relativeToChangelogFile="true"/> -->

</databaseChangeLog>
